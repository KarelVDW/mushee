# Copy to .env.development for local development. Every value below matches
# the code's built-in default, so an empty file also works — this is here to
# document the knobs.

# HTTP port the API listens on (web dev expects 4200).
PORT=4200

# Postgres — matches the docker-compose `postgres` service (host port 5632).
POSTGRES_HOST=localhost
POSTGRES_PORT=5632
POSTGRES_USER=mushee
POSTGRES_PASSWORD=mushee
POSTGRES_DB=mushee
# Or a single connection string (overrides the individual vars for auth):
# POSTGRES_URL=postgres://mushee:mushee@localhost:5632/mushee

# better-auth base URL (must match how the browser reaches the API).
BETTER_AUTH_URL=http://localhost:4200
# Extra origins allowed by better-auth/CORS beyond the dev default
# http://localhost:3200 (comma-separated).
# TRUSTED_ORIGINS=
# CORS_ORIGIN=http://localhost:3200

# Seed the demo accounts (all tiers + unlimited main account) on boot.
# `pnpm db:seed` does the same thing on demand.
# SEED_DEMO_DATA=true

# MusicXML storage. An rclone remote (`remote:bucket`) or a plain local
# directory path. rclone remotes can be configured entirely via
# RCLONE_CONFIG_<NAME>_* env vars — no rclone.conf needed.
# RCLONE_REMOTE=mushee-storage:mushee

# Pitch-model inference. Unset = in-process TF.js (the dev default, no extra
# services needed). Set to route a model's forward pass to its gRPC service.
# CREPE_INFERENCE_URL=localhost:50051
# BASIC_PITCH_INFERENCE_URL=localhost:50052
# INFERENCE_TIMEOUT_MS=15000
# Local model dirs for the in-process backend:
# BASIC_PITCH_MODEL_DIR=model
# CREPE_TINY_MODEL_DIR=model-crepe-tiny

# Outgoing mail (unset = emails are logged, not sent).
# SENDGRID_API_KEY=
# SENDGRID_FROM_EMAIL=no-reply@mushee.app
# SENDGRID_FROM_NAME=Sheemu
# SENDGRID_EU_RESIDENCY=true

# Public base URL of the web app — used for Polar redirect URLs and email
# links. Falls back to CORS_ORIGIN, then http://localhost:3200.
# WEB_APP_URL=https://sheemu.app

# ── Polar billing (https://polar.sh) ─────────────────────────────────────────
# Unset = billing disabled: /billing endpoints answer 503 and the UI hides
# paid actions. Use the sandbox (sandbox.polar.sh) while testing.
# POLAR_ACCESS_TOKEN=
# POLAR_WEBHOOK_SECRET=
# POLAR_SERVER=sandbox
# Product ids from the Polar dashboard, one per paid tier × interval:
# POLAR_PRODUCT_PRO_MONTHLY=
# POLAR_PRODUCT_PRO_YEARLY=
# POLAR_PRODUCT_STUDIO_MONTHLY=
# POLAR_PRODUCT_STUDIO_YEARLY=

# ── Closed beta ──────────────────────────────────────────────────────────────
# BETA_MODE=true → new signups join a waitlist on the 'beta' tier (5 min of
# recording/day) and need admin approval before they can use the app.
# The web app mirrors this switch as NEXT_PUBLIC_BETA_MODE.
# BETA_MODE=false
# Comma-separated emails that get the admin role (and beta auto-approval)
# when their account is created:
# ADMIN_EMAILS=
