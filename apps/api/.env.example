# Copy to .env.development for local development. Every value below matches
# the code's built-in default, so an empty file also works — this is here to
# document the knobs.

# HTTP port the API listens on (web dev expects 4200).
PORT=4200

# Postgres — matches the docker-compose `postgres` service (host port 5632).
POSTGRES_HOST=localhost
POSTGRES_PORT=5632
POSTGRES_USER=mushee
POSTGRES_PASSWORD=mushee
POSTGRES_DB=mushee
# Or a single connection string (honored by TypeORM, better-auth, and the
# seeder alike — overrides the individual vars):
# POSTGRES_URL=postgres://mushee:mushee@localhost:5632/mushee
# TLS to a managed database: 'require' (encrypted, unverified) or 'verify'
# (encrypted + verified against POSTGRES_SSL_CA). Default: off.
# POSTGRES_SSL=require
# POSTGRES_SSL_CA=
# Connection pool size per replica (TypeORM and better-auth each keep one).
# POSTGRES_POOL_SIZE=10

# better-auth base URL (must match how the browser reaches the API).
BETTER_AUTH_URL=http://localhost:4200
# Signs better-auth session tokens (read from the environment by the library
# itself). REQUIRED in production — boot aborts without it, since the
# library's fallback is a publicly known constant. Generate with:
# openssl rand -base64 32
# BETTER_AUTH_SECRET=
# Extra origins allowed by better-auth/CORS beyond the dev default
# http://localhost:3200 (comma-separated).
# TRUSTED_ORIGINS=
# CORS_ORIGIN=http://localhost:3200

# Seed the demo accounts (all tiers + unlimited main account) on boot.
# `pnpm db:seed` does the same thing on demand.
# SEED_DEMO_DATA=true

# Blob storage for score MusicXML + recording archives.
# 'local' (the default) writes under STORAGE_LOCAL_DIR; 'gcs' uses Google
# Cloud Storage (auth via Application Default Credentials — workload identity
# or GOOGLE_APPLICATION_CREDENTIALS). Just setting GCS_BUCKET implies gcs.
# STORAGE_DRIVER=local
# STORAGE_LOCAL_DIR=./storage
# GCS_BUCKET=
# GCS_PROJECT_ID=

# Pitch-model inference. Unset = in-process TF.js (the dev default, no extra
# services needed). Set to route a model's forward pass to its gRPC service.
# CREPE_INFERENCE_URL=localhost:50051
# BASIC_PITCH_INFERENCE_URL=localhost:50052
# INFERENCE_TIMEOUT_MS=15000
# Local model dirs for the in-process backend:
# BASIC_PITCH_MODEL_DIR=model
# CREPE_TINY_MODEL_DIR=model-crepe-tiny

# Outgoing mail (unset = emails are logged, not sent).
# SENDGRID_API_KEY=
# SENDGRID_FROM_EMAIL=no-reply@sheemu.com
# SENDGRID_FROM_NAME=Sheemu
# SENDGRID_EU_RESIDENCY=true

# Public base URL of the web app — used for Polar redirect URLs and email
# links. Falls back to CORS_ORIGIN, then http://localhost:3200.
# WEB_APP_URL=https://sheemu.com

# ── Polar billing (https://polar.sh) ─────────────────────────────────────────
# Unset = billing disabled: /billing endpoints answer 503 and the UI hides
# paid actions. Use the sandbox (sandbox.polar.sh) while testing.
# POLAR_ACCESS_TOKEN=
# POLAR_WEBHOOK_SECRET=
# POLAR_SERVER=sandbox
# Product ids from the Polar dashboard, one per paid tier × interval:
# POLAR_PRODUCT_PRO_MONTHLY=
# POLAR_PRODUCT_PRO_YEARLY=
# POLAR_PRODUCT_STUDIO_MONTHLY=
# POLAR_PRODUCT_STUDIO_YEARLY=

# ── Production hardening ─────────────────────────────────────────────────────
# Trust the X-Forwarded-For chain so per-IP rate limiting sees real client
# addresses behind an ingress. Takes `true`/`1`, a hop count, or a
# comma-separated CIDR list. Leave unset when clients connect directly.
# TRUST_PROXY=1
# Session-cookie domain when web + API live on different subdomains (e.g.
# sheemu.com + api.sheemu.com) — without it the cookie never reaches the web
# middleware and every signed-in user bounces to /login.
# COOKIE_DOMAIN=.sheemu.com
# Per-IP/session HTTP rate limit (`/health` exempt).
# RATE_LIMIT_MAX=120
# RATE_LIMIT_WINDOW=1 minute
# HTTP body size limit in bytes.
# MAX_BODY_BYTES=5242880
# Logs are structured JSON in production, human-readable in dev;
# 'json' / 'pretty' forces either.
# LOG_FORMAT=json
# Per-recording-session caps (defense in depth on top of credits).
# RECORDING_MAX_SECONDS=3600
# RECORDING_MAX_ENCODED_BYTES=134217728
# Debounce between windowed re-transcription passes.
# RECORDING_DEBOUNCE_MS=1000

# ── Closed beta ──────────────────────────────────────────────────────────────
# BETA_MODE=true → new signups join a waitlist on the 'beta' tier (5 min of
# recording/day) and need admin approval before they can use the app.
# The web app mirrors this switch as NEXT_PUBLIC_BETA_MODE.
# BETA_MODE=false
# Comma-separated emails that get the admin role (and beta auto-approval)
# when their account is created:
# ADMIN_EMAILS=
