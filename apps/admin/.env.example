# Copy to .env.development for local development. Every value below matches
# the code's built-in default, so an empty file also works.

# The console secret — what you type on the login screen. Must equal the API's
# ADMIN_SECRET (the console forwards it server-side on every admin API call;
# it never reaches the browser). Generate with: openssl rand -base64 32
# Unset = you can't sign in and the API answers 503.
# ADMIN_SECRET=

# Where THIS SERVER (not the browser) reaches the API — server-side proxy
# calls only, so no NEXT_PUBLIC_ prefix and no CORS involvement.
# Production: https://api.solkey.io
# API_URL=http://localhost:4200

# How long a console sign-in stays valid, in hours.
# ADMIN_SESSION_HOURS=12
