# Copy to .env.development for local development. The value below is also the
# code default, so an empty file works too.

# Where the browser reaches the API (pnpm dev runs it on 4200).
NEXT_PUBLIC_API_URL=http://localhost:4200

# Public site URL (canonical links, sitemap, Open Graph). Defaults to
# https://sheemu.com when unset.
# NEXT_PUBLIC_SITE_URL=https://sheemu.com

# PostHog (EU cloud) — unset = analytics fully disabled. Events are proxied
# through /ingest (see next.config.ts) and only sent after cookie consent.
# NEXT_PUBLIC_POSTHOG_KEY=phc_...
# NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# Closed beta UI (waitlist copy, /beta waiting room, no plan purchases).
# Must match the API's BETA_MODE.
# NEXT_PUBLIC_BETA_MODE=false
