{
    "name": "@mushee/notation",
    "version": "0.0.0",
    "private": true,
    "description": "Solkey's score domain: the versioned semantic model + pure layout engine, and the React notation renderer. Shipped as TypeScript source — consuming apps compile it with their own bundler (Next: transpilePackages).",
    "type": "module",
    "exports": {
        "./model": "./src/model/index.ts",
        "./model/*": "./src/model/*.ts",
        "./components": "./src/components/index.ts",
        "./components/*": "./src/components/*.ts",
        "./lib/*": "./src/lib/*.ts",
        "./testing": "./src/testing/index.ts"
    },
    "scripts": {
        "type-check": "tsc --noEmit",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage"
    },
    "dependencies": {
        "lodash-es": "^4.17.23"
    },
    "peerDependencies": {
        "react": "^19.0.0"
    },
    "devDependencies": {
        "@types/lodash-es": "^4.17.12",
        "@types/react": "^19",
        "@vitest/coverage-v8": "4.1.5",
        "happy-dom": "^20.9.0",
        "react": "19.2.3",
        "typescript": "^5.0.0",
        "vitest": "^4.1.5"
    }
}
